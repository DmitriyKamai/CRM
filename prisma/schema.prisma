// Prisma schema for Psychologist CRM
// Содержит модели пользователей, профилей, диагностики (Шмишек),
// расписания и пользовательских полей.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Прямое подключение к БД (без пулера) для миграций.
  directUrl = env("DIRECT_DATABASE_URL")
  // Теневая база для migrate diff / baseline
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum Role {
  UNSPECIFIED
  CLIENT
  PSYCHOLOGIST
  ADMIN
}

enum SlotStatus {
  FREE
  BOOKED
  CANCELED
}

enum AppointmentStatus {
  PENDING_CONFIRMATION
  SCHEDULED
  COMPLETED
  CANCELED
  NO_SHOW
}

enum CustomFieldTarget {
  CLIENT
  APPOINTMENT
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  SELECT
  MULTILINE
  BOOLEAN
  MULTI_SELECT
}

enum TestType {
  SHMISHEK
  PAVLOVA_SHMISHEK
  SMIL
}


// --- NextAuth core models ---

model User {
  id             String    @id @default(cuid())
  name           String?
  firstName      String?
  lastName       String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  dateOfBirth    DateTime?
  phone          String?
  country        String?
  city           String?
  gender         String?   // male | female | other
  maritalStatus  String?   // single | married | divorced | widowed | unspecified
  hashedPassword String?
  role           Role      @default(UNSPECIFIED)
  telegramChatId String?   // привязка к Telegram для уведомлений и бота
  telegramUsername String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  notifications Notification[]
  telegramLinkTokens TelegramLinkToken[]
  passwordResetTokens PasswordResetToken[]

  psychologistProfile PsychologistProfile?
  clientProfiles      ClientProfile[]

  // Обратная связь для AuditLog.actor
  auditLogs AuditLog[] @relation("AuditLogActor")

  clientHistoryEventsAuthored ClientHistoryEvent[] @relation("ClientHistoryActor")

  /// Сессии входа (браузер) для списка устройств и отзыва «остальные».
  authLoginSessions AuthLoginSession[]
}

/// Активная браузерная сессия: стабильный ключ в JWT (`loginSessionKey`), не путать с JWE jti NextAuth.
model AuthLoginSession {
  id          String    @id @default(cuid())
  userId      String
  sessionKey  String    @unique
  userAgent   String?   @db.Text
  browser     String?
  os          String?
  deviceLabel String?
  country     String?
  city        String?
  createdAt   DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  revokedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, revokedAt])
}

/// Одноразовые токены для привязки Telegram (ссылка с сайта → бот).
model TelegramLinkToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expiresAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String?  @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?
  oauth_token_secret String? @db.Text
  oauth_token        String? @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Токены для восстановления пароля (по email).
model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// --- Domain: profiles ---

model PsychologistProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  specialization String?  // psychologist | psychotherapist | psychiatrist
  bio            String?  @db.Text
  // Публичные контакты для клиентов
  contactPhone       String?
  contactTelegram    String?
  contactViber       String?
  contactWhatsapp    String?
  profilePhotoUrl     String?   // фото для карточки в «Записаться к психологу» (отдельно от User.image — аватар)
  /// Латиница, цифры и дефис; алиас публичного URL (если задан — канонический путь).
  publicSlug            String?  @unique
  /// Порядковый номер среди психологов по дате регистрации (`createdAt`); канонический путь `/id{N}` без алиаса.
  publicRouteSerial     Int      @unique
  /// Публичная страница доступна по алиасу, по /id{N} или по legacy cuid.
  profilePagePublished  Boolean  @default(false)
  /// Карточка в каталоге «Найти психолога» (страница при этом тоже должна быть опубликована).
  catalogVisible        Boolean  @default(false)
  /// Город и страна приёма для клиентов (не путать с личным адресом в User).
  practiceCountry       String?
  practiceCity          String?
  worksOnline           Boolean  @default(false)
  settingsJson   Json?    // общие настройки, включая параметры расписания по умолчанию
  /// OAuth refresh token Google Sheets. При `GOOGLE_SHEETS_TOKEN_ENCRYPTION_KEY` шифруется в приложении (см. lib/google-sheets-refresh-token-crypto.ts, DEPLOY.md).
  googleSheetsRefreshToken String? @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  clients                 ClientProfile[]       @relation("PsychologistClients")
  clientFiles             ClientFile[]
  scheduleSlots           ScheduleSlot[]
  customFieldDefinitions  CustomFieldDefinition[]
  testResults             TestResult[]
  recommendationsAuthored Recommendation[]
  diagnosticLinks         DiagnosticLink[]
  appointments            Appointment[]
  clientRegistrationInvites ClientRegistrationInvite[]
  clientStatuses            ClientStatus[]
  calendarFeedToken         CalendarFeedToken?
}

/// Секретная ссылка ICS-календаря (можно перевыпустить — старая перестаёт работать).
model CalendarFeedToken {
  id             String    @id @default(cuid())
  token          String    @unique
  psychologistId String    @unique
  createdAt      DateTime  @default(now())
  /// Когда внешний календарь последний раз успешно запросил ICS (best-effort).
  lastFetchedAt  DateTime?

  psychologist PsychologistProfile @relation(fields: [psychologistId], references: [id], onDelete: Cascade)

  @@index([token])
}

/// Аудит-лог критичных действий (best-effort, без блокировки основных сценариев).
model AuditLog {
  id String @id @default(cuid())

  createdAt DateTime @default(now())

  actorUserId String?
  actorRole   String?

  action     String
  targetType String?
  targetId   String?

  ip   String?
  meta Json?

  actor User? @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([actorUserId])
  @@index([action, createdAt])
}

model ClientProfile {
  id             String   @id @default(cuid())
  userId         String?
  email          String?  // для связки при регистрации, когда userId ещё нет
  /// Может быть null для профиля после social-complete до привязки к психологу; в сценариях психолог↔клиент должен быть задан (API создания/импорта).
  psychologistId String?
  firstName      String
  lastName       String
  dateOfBirth    DateTime?
  phone          String?
  country        String?
  city           String?
  gender         String?  // male | female | other
  maritalStatus  String?  // single | married | divorced | widowed | unspecified
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  statusId       String?

  user         User?                @relation(fields: [userId], references: [id])
  psychologist PsychologistProfile? @relation("PsychologistClients", fields: [psychologistId], references: [id])
  status       ClientStatus?        @relation(fields: [statusId], references: [id])
  files        ClientFile[]

  @@unique([psychologistId, email])
  @@index([userId])
  @@index([psychologistId])
  @@index([email])
  @@index([statusId])
  @@index([psychologistId, createdAt(sort: Desc)])
  @@index([psychologistId, statusId, createdAt(sort: Desc)])

  testResults         TestResult[]
  appointments        Appointment[]      @relation("ClientAppointments")
  customFieldValues   CustomFieldValue[]
  recommendationsReceived Recommendation[]
  diagnosticLinks         DiagnosticLink[]
  clientRegistrationInvites ClientRegistrationInvite[]
  historyEvents           ClientHistoryEvent[]
}

/// События по клиенту для ленты «История» (отдельно от глобального AuditLog).
model ClientHistoryEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  clientId String
  client   ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)

  type String

  actorUserId String?
  actor       User?   @relation("ClientHistoryActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  meta Json?

  @@index([clientId, createdAt(sort: Desc)])
}

model ClientStatus {
  id             String   @id @default(cuid())
  psychologistId String
  key            String
  label          String
  color          String   // например, hsl(...) или tailwind-класс, но мы будем хранить hex/hsl
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  psychologist PsychologistProfile @relation(fields: [psychologistId], references: [id])
  clients      ClientProfile[]

  @@unique([psychologistId, key])
  @@index([psychologistId, order])
}

// --- Domain: diagnostics (tests, questions, results) ---

model Test {
  id          String   @id @default(cuid())
  type        TestType
  title       String
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions TestQuestion[]
  scales    TestScale[]
  results   TestResult[]
  links     DiagnosticLink[]

  @@unique([type])
}

model TestQuestion {
  id     String @id @default(cuid())
  testId String
  index  Int
  text   String
  meta   Json?

  test Test @relation(fields: [testId], references: [id])

  @@unique([testId, index])
}

model TestScale {
  id          String @id @default(cuid())
  testId      String
  key         String
  title       String
  description String? @db.Text
  meta        Json?

  test Test @relation(fields: [testId], references: [id])

  @@unique([testId, key])
}

model TestResult {
  id              String   @id @default(cuid())
  testId          String
  clientId        String?
  psychologistId  String?
  rawAnswers      Json    // карта: индекс вопроса -> ответ
  scaleScores     Json    // карта: ключ шкалы -> числовой балл
  interpretation  String? @db.Text
  createdAt       DateTime @default(now())

  test         Test               @relation(fields: [testId], references: [id])
  client       ClientProfile?     @relation(fields: [clientId], references: [id])
  psychologist PsychologistProfile? @relation(fields: [psychologistId], references: [id])
  recommendations Recommendation[]

  @@index([clientId])
  @@index([psychologistId])
}

// Ссылки, по которым клиент может пройти опросник (например, Шмишека)
model DiagnosticLink {
  id             String   @id @default(cuid())
  testId         String
  psychologistId String?
  clientId       String?
  token          String   @unique
  expiresAt      DateTime?
  maxUses        Int?
  usedCount      Int      @default(0)
  createdAt      DateTime @default(now())

  test     Test                     @relation(fields: [testId], references: [id])
  psychologist PsychologistProfile? @relation(fields: [psychologistId], references: [id])
  client   ClientProfile?           @relation(fields: [clientId], references: [id])
  progress DiagnosticProgress?

  @@index([token])
}

// Черновик прохождения теста (прогресс до отправки результата)
model DiagnosticProgress {
  id               String   @id @default(cuid())
  diagnosticLinkId String   @unique
  answers          Json     // Record<number, 0|1|2|3>
  currentStep      Int      @default(0) // 0 = инструкция, 1..N = вопрос
  meta             Json?    // для СМИЛ: { variant, gender?, age? }
  updatedAt       DateTime @updatedAt

  link DiagnosticLink @relation(fields: [diagnosticLinkId], references: [id], onDelete: Cascade)
}

// Приглашение клиента к регистрации в личном кабинете
model ClientRegistrationInvite {
  id             String   @id @default(cuid())
  token          String   @unique
  clientId       String
  psychologistId String
  email          String
  createdAt      DateTime @default(now())
  usedAt         DateTime?

  client       ClientProfile       @relation(fields: [clientId], references: [id])
  psychologist PsychologistProfile @relation(fields: [psychologistId], references: [id])

  @@unique([clientId, psychologistId])
  @@index([clientId])
  @@index([psychologistId])
}

// --- Domain: schedule & appointments ---

model ScheduleSlot {
  id             String      @id @default(cuid())
  psychologistId String
  start          DateTime
  end            DateTime
  status         SlotStatus  @default(FREE)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  psychologist PsychologistProfile @relation(fields: [psychologistId], references: [id])
  appointment  Appointment?

  @@index([psychologistId, start])
}

model Appointment {
  id                     String            @id @default(cuid())
  slotId                 String?           @unique
  psychologistId         String
  clientId               String
  start                  DateTime
  end                    DateTime
  status                 AppointmentStatus @default(SCHEDULED)
  /// При записи из API использовать encryptAppointmentNotesForDb (lib/server-encryption).
  notes                  String?           @db.Text
  proposedByPsychologist Boolean           @default(false)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  slot         ScheduleSlot?       @relation(fields: [slotId], references: [id])
  psychologist PsychologistProfile @relation(fields: [psychologistId], references: [id])
  client       ClientProfile       @relation("ClientAppointments", fields: [clientId], references: [id])
  customFieldValues CustomFieldValue[]

  @@index([psychologistId, start])
  @@index([clientId, start])
}

// --- Domain: custom fields ---

model CustomFieldDefinition {
  id             String            @id @default(cuid())
  psychologistId String
  target         CustomFieldTarget
  key            String
  label          String
  description    String?  @db.Text
  type           CustomFieldType
  group          String?
  order          Int               @default(0)
  options        Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  psychologist PsychologistProfile @relation(fields: [psychologistId], references: [id])
  values       CustomFieldValue[]

  @@unique([psychologistId, target, key])
}

model CustomFieldValue {
  id            String   @id @default(cuid())
  definitionId  String
  clientId      String?
  appointmentId String?
  value         Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  definition  CustomFieldDefinition @relation(fields: [definitionId], references: [id])
  client      ClientProfile?        @relation(fields: [clientId], references: [id])
  appointment Appointment?          @relation(fields: [appointmentId], references: [id])

  @@index([clientId])
  @@index([appointmentId])
}

/// Файлы, прикреплённые к профилю клиента конкретного психолога.
model ClientFile {
  id             String   @id @default(cuid())
  psychologistId String
  clientId       String
  url            String
  filename       String
  mimeType       String
  size           Int
  createdAt      DateTime @default(now())

  psychologist PsychologistProfile @relation(fields: [psychologistId], references: [id])
  client       ClientProfile       @relation(fields: [clientId], references: [id])

  @@index([psychologistId, clientId])
}

// --- Domain: recommendations ---

model Recommendation {
  id             String   @id @default(cuid())
  psychologistId String
  clientId       String
  testResultId   String?
  title          String
  body           String   @db.Text
  createdAt      DateTime @default(now())

  psychologist PsychologistProfile @relation(fields: [psychologistId], references: [id])
  client       ClientProfile       @relation(fields: [clientId], references: [id])
  testResult   TestResult?        @relation(fields: [testResultId], references: [id])

  @@index([psychologistId])
  @@index([clientId])
}

// --- Глобальные переключатели модулей (одна строка id = default) ---

model PlatformSettings {
  id                 String   @id
  schedulingEnabled  Boolean  @default(true)
  diagnosticsEnabled Boolean  @default(true)
  updatedAt          DateTime @updatedAt
}

