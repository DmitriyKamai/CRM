{
  "name": "psychologist-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:no": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" next dev --webpack",
    "dev:turbopack": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" next dev",
    "dev": "next build && next start",
    "dev:stable": "next build && next start",
    "dev:debug": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096 --unhandled-rejections=strict\" next dev --webpack",
    "build": "prisma generate && node scripts/migrate-deploy.js && next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "security:audit": "npm audit --omit=dev",
    "security:check": "npm run typecheck && npm run lint && npm run security:audit",
    "prisma:generate": "prisma generate",
    "prisma:generate:clean": "node scripts/clean-prisma-engine.js && prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "node scripts/migrate-deploy.js",
    "prisma:seed": "tsx prisma/seed-shmishek.ts && tsx prisma/seed-pavlova.ts && tsx prisma/seed-smil.ts",
    "prisma:seed-shmishek": "tsx prisma/seed-shmishek.ts",
    "prisma:seed-pavlova": "tsx prisma/seed-pavlova.ts",
    "prisma:seed-smil": "tsx prisma/seed-smil.ts",
    "bot": "tsx scripts/telegram-bot.ts",
    "vercel:delete-old": "node scripts/delete-old-vercel-deployments.js",
    "postinstall": "node scripts/patch-next-dev.js"
  },
