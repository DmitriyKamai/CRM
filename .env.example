# Скопируйте в .env и заполните. Файл .env в git не коммитится.

DATABASE_URL=
DIRECT_DATABASE_URL=

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Rate limiting (optional)
# Upstash Redis (recommended for serverless)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Standard Redis (optional)
REDIS_URL=

# Первый администратор (email пользователя в системе)
# INITIAL_ADMIN_EMAIL=

# Импорт клиентов из Google Таблиц — ключ сервисного аккаунта Google Cloud.
# Таблицу расшарьте на email из поля client_email в JSON (достаточно «Читатель»).
#
# Вариант A: JSON одной строкой (многострочный JSON в .env обычно НЕ читается целиком).
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# Вариант B: путь к скачанному .json (удобно для локальной разработки).
# GOOGLE_SERVICE_ACCOUNT_PATH=D:\secrets\crm-sa.json
# или стандартная переменная Google:
# GOOGLE_APPLICATION_CREDENTIALS=D:\secrets\crm-sa.json
#
# Вариант C: содержимое JSON в Base64 одной строкой (удобно на Vercel и т.п.).
# GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=eyJ0eXBlIjoi...
