# Скопируйте в .env и заполните. Файл .env в git не коммитится.

DATABASE_URL=
DIRECT_DATABASE_URL=

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Rate limiting (optional)
# Upstash Redis (recommended for serverless)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Standard Redis (optional)
REDIS_URL=

# Первый администратор (email пользователя в системе)
# INITIAL_ADMIN_EMAIL=

# Экспорт клиентов в Google Таблицы (JSON сервисного аккаунта Google Cloud, одна строка).
# Таблицу нужно расшарить на email из поля client_email в JSON с правом «Редактор».
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
