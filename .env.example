# Скопируйте в .env и заполните. Файл .env в git не коммитится.

# Серверное шифрование чувствительных полей (AES-256-GCM). Для production задайте стабильный ключ
# и храните его только в секретах (Vercel Env, CI и т.д.). Без ключа приложение стартует, но
# зашифрованные в БД поля не прочитаются/не запишутся корректно.
# Сгенерировать: openssl rand -base64 32
# Или без OpenSSL: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Миграция старых plaintext → envelope: npm run encrypt:sensitive-fields
DATA_ENCRYPTION_KEY=

DATABASE_URL=
DIRECT_DATABASE_URL=

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Список активных сессий: гео по IP (ipwho.is). Значение 0 — не вызывать внешний API (только заголовки CDN/Vercel).
# AUTH_LOGIN_SESSION_GEO=0

# Vercel Cron: очистка слотов расписания каждые 15 мин (см. vercel.json).
# В Vercel задайте CRON_SECRET — запросы к /api/cron/schedule-slot-cleanup идут с Authorization: Bearer <CRON_SECRET>.
# CRON_SECRET=

# Rate limiting (optional)
# Upstash Redis (recommended for serverless)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Standard Redis (optional)
REDIS_URL=

# Первый администратор (email пользователя в системе)
# INITIAL_ADMIN_EMAIL=

# Импорт из Google Таблиц — OAuth пользователя (те же переменные, что для входа через Google).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# В Google Cloud Console → Credentials → OAuth client → Authorized redirect URIs добавьте:
#   {NEXTAUTH_URL}/api/psychologist/google-sheets/oauth/callback
# например: http://localhost:3000/api/psychologist/google-sheets/oauth/callback
# Пока приложение в режиме «Testing» (OAuth consent screen), в Test users добавьте email каждого
# пользователя, иначе Google вернёт 403 access_denied.
# Окно выбора таблицы (Google Picker): включите API «Google Picker API» и «Google Drive API»,
# создайте ключ API (HTTP referrer — ваш домен). Публичная переменная для фронта:
# NEXT_PUBLIC_GOOGLE_API_KEY=
# В OAuth consent screen добавьте scope: .../auth/drive.readonly (и spreadsheets.readonly).
# После добавления scope пользователи должны заново нажать «Подключить Google».
